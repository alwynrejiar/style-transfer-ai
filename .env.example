# Environment Configuration for Style Transfer AI
# Copy this file to .env and replace placeholders with your actual values

# ---------------------------------------------------------------------------
# Supabase (required for authentication only)
# Get these from: Supabase Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key-here

# ---------------------------------------------------------------------------
# Ollama Configuration (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEMMA_MODEL=gemma3:1b

# ---------------------------------------------------------------------------
# Gemini Configuration (cloud LLM)
# Get key from: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# Analysis Configuration
# ---------------------------------------------------------------------------
DEFAULT_MODEL_TYPE=local
DEFAULT_LOCAL_MODEL=gemma3:1b

# ---------------------------------------------------------------------------
# File Paths (customize as needed)
# ---------------------------------------------------------------------------
LOCAL_DATA_DIR=local_data
TEXT_SAMPLE_1=about_my_pet.txt
TEXT_SAMPLE_2=about_my_pet_1.txt
OUTPUT_PROFILE=user_style_profile.json

# ---------------------------------------------------------------------------
# Security Settings
# ---------------------------------------------------------------------------
VALIDATE_API_KEYS=true
MASK_API_KEYS_IN_LOGS=true
